# =============================================================================
# FRLM — Secrets & Credentials
#
# Copy this file to secrets.properties and fill in your actual values.
#   cp config/secrets.properties.example config/secrets.properties
#
# This file is loaded by config/config.py and overrides values in default.yaml.
# Do NOT commit secrets.properties to version control.
# =============================================================================

# -- Neo4j --------------------------------------------------------------------
neo4j.uri=bolt://localhost:7687
neo4j.username=neo4j
neo4j.password=CHANGE_ME
neo4j.database=neo4j

# -- Anthropic (Claude API) --------------------------------------------------
anthropic.api_key=CHANGE_ME

# -- Weights & Biases --------------------------------------------------------
wandb.api_key=CHANGE_ME

# -- NCBI (PubMed Central) ---------------------------------------------------
ncbi.api_key=


